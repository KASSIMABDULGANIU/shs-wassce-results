<Window x:Class="SHSWassceResultsMgt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://schemas.materialdesigninxaml.com/winfx/xaml/themes"
        Title="SHS WASSCE Results Management" Height="760" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource MaterialDesignFont}"
        Background="{StaticResource MaterialDesignBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SIDEBAR ── -->
        <Border Grid.Column="0" Background="#1E1B4B">
            <DockPanel>

                <!-- Logo / School Name -->
                <StackPanel DockPanel.Dock="Top" Margin="20,28,20,24">
                    <TextBlock Text="SHS WASSCE" FontSize="20" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Results Management" FontSize="11"
                               Foreground="#A5B4FC" Margin="0,2,0,0"/>
                    <Separator Margin="0,16,0,0" Background="#3730A3"/>
                </StackPanel>

                <!-- Version at bottom -->
                <TextBlock DockPanel.Dock="Bottom" x:Name="VersionLabel"
                           Foreground="#6366F1" FontSize="10"
                           Margin="20,0,20,16" HorizontalAlignment="Left"/>

                <!-- Nav buttons -->
                <StackPanel Margin="10,0">
                    <Button x:Name="BtnDashboard"  Content="📊  Dashboard"       Click="Nav_Click" Tag="Dashboard"  Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="BtnStudents"   Content="👨‍🎓  Students"         Click="Nav_Click" Tag="Students"   Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="BtnSubjects"   Content="📚  Subjects"         Click="Nav_Click" Tag="Subjects"   Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="BtnScores"     Content="✏️  Score Entry"      Click="Nav_Click" Tag="Scores"     Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="BtnRankings"   Content="🏆  Rankings"         Click="Nav_Click" Tag="Rankings"   Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="BtnReports"    Content="🖨️  Reports / Print"  Click="Nav_Click" Tag="Reports"   Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="BtnStaff"      Content="👤  Staff"            Click="Nav_Click" Tag="Staff"      Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="BtnSettings"   Content="⚙️  Settings"         Click="Nav_Click" Tag="Settings"  Style="{StaticResource NavButtonStyle}"/>

                    <Separator Margin="10,12" Background="#3730A3"/>

                    <Button Content="🔄  Check for Updates" Click="CheckUpdates_Click"
                            Style="{StaticResource NavButtonStyle}" Foreground="#A5B4FC"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── CONTENT AREA ── -->
        <Border Grid.Column="1" Padding="28">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>
