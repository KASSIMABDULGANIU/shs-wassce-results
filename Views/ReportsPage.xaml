<Page x:Class="SHSWassceResultsMgt.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Reports" Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Reports / Print" Style="{StaticResource PageTitle}"/>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource FormCard}">
            <WrapPanel>
                <ComboBox x:Name="ClassFilter" Width="140" md:HintAssist.Hint="Class" SelectionChanged="ClassFilter_Changed" Margin="0,0,10,8"/>
                <ComboBox x:Name="StudentFilter" Width="240" md:HintAssist.Hint="Student" DisplayMemberPath="Name" Margin="0,0,10,8"/>
                <TextBox  x:Name="YearBox" Width="120" md:HintAssist.Hint="Academic Year" Text="2025/2026" Margin="0,0,10,8"/>
                <TextBox  x:Name="TermBox" Width="80"  md:HintAssist.Hint="Term" Text="1" Margin="0,0,16,8"/>
                <Button Content="Preview" Click="Preview_Click" Margin="0,0,6,8"/>
                <Button Content="Export PDF" Click="ExportPdf_Click" Margin="0,0,0,8"/>
            </WrapPanel>
        </Border>

        <!-- Preview grid -->
        <DataGrid Grid.Row="2" x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  md:DataGridAssist.CellPadding="10,6">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Subject"     Binding="{Binding SubjectName}" Width="220"/>
                <DataGridTextColumn Header="Class Score" Binding="{Binding ClassScore}"  Width="110"/>
                <DataGridTextColumn Header="Exam Score"  Binding="{Binding ExamScore}"   Width="110"/>
                <DataGridTextColumn Header="Total"       Binding="{Binding Total}"       Width="90"/>
                <DataGridTextColumn Header="Grade"       Binding="{Binding Grade}"       Width="70"/>
                <DataGridTextColumn Header="Remark"      Binding="{Binding Remark}"      Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" x:Name="Status" Opacity="0.6" FontSize="12" Margin="0,8,0,0"/>
    </Grid>
</Page>
