<Page x:Class="SHSWassceResultsMgt.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" Background="Transparent">
    <ScrollViewer>
        <StackPanel Margin="0,0,0,40">

            <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock x:Name="SubTitle" FontSize="13" Opacity="0.6" Margin="0,0,0,28"/>

            <!-- Stats row -->
            <UniformGrid Columns="4" Margin="0,0,0,32">
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Total Students" Style="{StaticResource StatLabel}"/>
                        <TextBlock x:Name="CountStudents" Text="0" Style="{StaticResource StatValue}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Subjects" Style="{StaticResource StatLabel}"/>
                        <TextBlock x:Name="CountSubjects" Text="0" Style="{StaticResource StatValue}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Scores Recorded" Style="{StaticResource StatLabel}"/>
                        <TextBlock x:Name="CountScores" Text="0" Style="{StaticResource StatValue}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Staff" Style="{StaticResource StatLabel}"/>
                        <TextBlock x:Name="CountStaff" Text="0" Style="{StaticResource StatValue}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Quick tips -->
            <TextBlock Text="Getting Started" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <Border Background="#F5F3FF" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="1.  Go to Students → add your class list" Margin="0,4"/>
                    <TextBlock Text="2.  Go to Subjects → confirm subjects per program" Margin="0,4"/>
                    <TextBlock Text="3.  Go to Score Entry → select class + subject → enter scores" Margin="0,4"/>
                    <TextBlock Text="4.  Go to Rankings → see class positions auto-computed" Margin="0,4"/>
                    <TextBlock Text="5.  Go to Reports → print individual result slips as PDF" Margin="0,4"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
