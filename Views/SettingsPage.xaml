<Page x:Class="SHSWassceResultsMgt.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Settings" Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings — Grading Scale" Style="{StaticResource PageTitle}"/>

        <TextBlock Grid.Row="1" Margin="0,0,0,12" Opacity="0.7"
                   Text="Adjust the score ranges, WASSCE grade (1-9) and remark below. Edit cells directly, then click Save."/>

        <DataGrid Grid.Row="2" x:Name="Grid" AutoGenerateColumns="False" CanUserAddRows="False"
                  md:DataGridAssist.CellPadding="10,6">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Min Score" Binding="{Binding MinScore}" Width="120"/>
                <DataGridTextColumn Header="Max Score" Binding="{Binding MaxScore}" Width="120"/>
                <DataGridTextColumn Header="Grade"     Binding="{Binding Grade}"    Width="100"/>
                <DataGridTextColumn Header="Remark"    Binding="{Binding Remark}"   Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Save Changes" Click="Save_Click" Margin="0,0,6,0"/>
            <Button Content="Reload" Click="Reload_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
            <TextBlock x:Name="Status" Opacity="0.6" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>
    </Grid>
</Page>
