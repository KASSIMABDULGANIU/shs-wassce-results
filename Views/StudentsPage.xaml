<Page x:Class="SHSWassceResultsMgt.Views.StudentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Students" Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Students" Style="{StaticResource PageTitle}"/>

        <!-- Form -->
        <Border Grid.Row="1" Style="{StaticResource FormCard}">
            <WrapPanel>
                <TextBox x:Name="NameBox"    Width="180" md:HintAssist.Hint="Full Name *"       Margin="0,0,10,8"/>
                <TextBox x:Name="IndexBox"   Width="130" md:HintAssist.Hint="Index Number"       Margin="0,0,10,8"/>
                <ComboBox x:Name="GenderBox" Width="100" md:HintAssist.Hint="Gender"             Margin="0,0,10,8">
                    <ComboBoxItem Content="Male"/>
                    <ComboBoxItem Content="Female"/>
                </ComboBox>
                <TextBox x:Name="ClassBox"   Width="100" md:HintAssist.Hint="Class e.g. 3A"     Margin="0,0,10,8"/>
                <TextBox x:Name="ProgramBox" Width="150" md:HintAssist.Hint="Program"            Margin="0,0,10,8"/>
                <TextBox x:Name="YearBox"    Width="110" md:HintAssist.Hint="Academic Year"      Margin="0,0,10,8"/>
                <TextBox x:Name="TermBox"    Width="70"  md:HintAssist.Hint="Term"               Margin="0,0,16,8"/>
                <Button Content="Add"    Click="Add_Click"    Margin="0,0,6,8"/>
                <Button Content="Update" Click="Update_Click" Margin="0,0,6,8" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                <Button Content="Delete" Click="Delete_Click" Margin="0,0,0,8"  Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="Red"/>
                <Button Content="Clear"  Click="Clear_Click"  Margin="6,0,0,8"  Style="{StaticResource MaterialDesignFlatButton}"/>
            </WrapPanel>
        </Border>

        <!-- Grid -->
        <DataGrid Grid.Row="2" x:Name="Grid" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionChanged="Grid_SelectionChanged"
                  md:DataGridAssist.CellPadding="12,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"           Binding="{Binding Id}"           Width="50"/>
                <DataGridTextColumn Header="Name"        Binding="{Binding Name}"          Width="200"/>
                <DataGridTextColumn Header="Index No."   Binding="{Binding IndexNumber}"   Width="120"/>
                <DataGridTextColumn Header="Gender"      Binding="{Binding Gender}"        Width="80"/>
                <DataGridTextColumn Header="Class"       Binding="{Binding ClassName}"     Width="80"/>
                <DataGridTextColumn Header="Program"     Binding="{Binding Program}"       Width="150"/>
                <DataGridTextColumn Header="Year"        Binding="{Binding AcademicYear}"  Width="100"/>
                <DataGridTextColumn Header="Term"        Binding="{Binding Term}"          Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" x:Name="Status" Opacity="0.6" FontSize="12" Margin="0,8,0,0"/>
    </Grid>
</Page>
